[sub_resource type="GDScript" id="GDScript_0wfyh"]
script/source = "extends Node2D

@onready var template_ball := $Ball
@onready var attack_label := $UI/AttackLabel
@onready var box_out := $BoxOut
@onready var game_manager := $GameManager

var spawn_position: Vector2
var current_attack_level: int = 0

func _ready() -> void:
	randomize()
	spawn_position = template_ball.position
	update_attack_label()
	template_ball.dropped.connect(_on_ball_dropped)

func _on_draw_pressed() -> void:
	box_out.rotate_cup()

func _on_ball_dropped() -> void:
	get_tree().create_timer(1.0).timeout.connect(game_manager._card_play_toggle)
	get_tree().create_timer(1.0).timeout.connect(spawn_ball)

func spawn_ball() -> void:
	var b := template_ball.duplicate()
	Global.ballInPlay = b
	b.position = spawn_position
	b.set_up = false
	b.visible = false
	b.gravity_scale = 0.0
	b.level = 1
	b.dropped.connect(_on_ball_dropped)
	add_child(b)
	current_attack_level = b.level
	update_attack_label()

func update_attack_label() -> void:
	if current_attack_level > 0:
		attack_label.text = \"Attack %d\" % current_attack_level
	else:
		attack_label.text = \"Attack -\"
"

